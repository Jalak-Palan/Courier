# Root gitignore for Courier Monorepo

# Node modules
**/node_modules/

# Environment files
**/.env
**/.env.*
!**/.env.example

# Production builds
**/dist/
**/dist-ssr/

# Logs
**/logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/pnpm-debug.log*
**/lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Scraper caches (for backend)
**/.cache/
